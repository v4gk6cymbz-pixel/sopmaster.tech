# Database — Turso (hosted SQLite, create free DB at https://turso.tech)
DATABASE_URL=libsql://your-db.your-region.turso.io
TURSO_DATABASE_URL=libsql://your-db.your-region.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# JWT Secret (generate a strong random value)
JWT_SECRET=your-random-secret-min-32-chars

# Stripe — Keys (use test keys for development)
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Stripe Customer Portal (configure at https://dashboard.stripe.com/portal)
# NEXT_PUBLIC_STRIPE_CUSTOMER_PORTAL_LINK=https://billing.stripe.com/p/login/xxx

# Director email (the account that has admin access)
NEXT_PUBLIC_DIRECTOR_EMAIL=admin@yourcompany.com

# App URL (no trailing slash)
APP_URL=http://localhost:3000

# Subscription Price IDs (create in Stripe Dashboard → Products)
STRIPE_PRICE_SOLO=price_xxx
STRIPE_PRICE_SMALL=price_xxx
STRIPE_PRICE_MEDIUM=price_xxx
STRIPE_PRICE_LARGE=price_xxx

# Credit Pack Price IDs
STRIPE_PRICE_CREDITS_100=price_xxx
STRIPE_PRICE_CREDITS_300=price_xxx
STRIPE_PRICE_CREDITS_500=price_xxx
STRIPE_PRICE_CREDITS_1000=price_xxx
